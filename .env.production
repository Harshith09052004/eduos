# Mandatory — generate with: openssl rand -hex 32
DJANGO_SECRET_KEY=replace-with-a-random-64-char-string

# Your Oracle VM's public IP (get from Oracle Cloud Console)
VPS_IP=your.vm.public.ip

# Database password
DB_PASSWORD=change-this-to-a-strong-password

# Email (optional — remove these lines if not needed)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
